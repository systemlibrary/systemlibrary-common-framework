{
  "Logging": {
    "LogLevel": {
      "Default": "None"
    }
  },

  "systemLibraryCommonFramework": {
    "debug": true,

    "dump": {
      "folder": "%HomeDrive%\\Logs\\",
      "fileName": "systemlibrary-common-framework-tests.log"
    },
    "json": {
      "writeIndented": true,
      "maxDepth": 99,
      "allowTrailingCommas": false,
      "propertyNameCaseInsensitive": true,
      "readCommentHandling": "Disallow"
    }
  }
}