{
  "systemLibraryCommonFramework": {
    "debug": true,

    "log": {
      "fullFilePath": "%HomeDrive%\\Logs\\systemlibrary-common-framework-app-tests.log",
      "level": "Information",
      "format": "json",
      "addUrl": true,
      "addHttpMethod": false,
      "addAuthenticatedState": true,
      "addStackTrace": false,
      "addIP": false,
      "addBrowserName": false,
      "addCorrelationId": true
    },
    "json": {
      "allowTrailingCommas": false,
      "maxDepth": 99,
      "propertyNameCaseInsensitive": true,
      "jsonCommentHandling": "skip",
      "jsonIgnoreCondition": "whenWritingDefault",
      "writeIndented": true,
      "ignoreReadOnlyFields": true,
      "includeFields": true
    },

    "metrics": {
      "enable": true,
      "authorizationValue": ""
    }
  }
}