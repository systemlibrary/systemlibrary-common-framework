{
  "Logging": {
    "LogLevel": {
      "Default": "None"
    }
  },

  "systemLibraryCommonFramework": {
    "client": {
      "timeout": 8686,
      "retryTimeout": 5500,
      "ignoreSslErrors": true,
      "useRetryPolicy": true,
      "disableExpectContinue": true,
      "useAutomaticDecompression": true,
      "throwOnUnsuccessful": true,
      "useRequestBreakerPolicy": true,
      "clientCacheDuration": 1200
    }
  }
}